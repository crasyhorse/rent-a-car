{
    "name": "rent-a-car",
    "version": "1.0.0",
    "description": "A Node.js / Express.js based example REST API for a Rent-A-Car app.",
    "packageManager": "pnpm@9.15.0",
    "type": "module",
    "main": "src/main.ts",
    "scripts": {
        "dev": "nodemon -r tsconfig-paths/register -x tsx src/main.ts",
        "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json",
        "test": "vitest --coverage"
    },
    "author": "Crasyhorse",
    "license": "MIT",
    "engines": {
        "node": ">= 18"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@tsconfig/node20": "^20.1.9",
        "@types/body-parser": "^1.19.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/morgan": "^1.9.10",
        "@types/node": "^20.19.37",
        "@vitest/coverage-istanbul": "4.1.2",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "nodemon": "^3.1.14",
        "npm-run-all2": "^7.0.2",
        "prettier": "^3.8.1",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.58.0",
        "vite": "^7.3.1",
        "vitest": "^4.1.2"
    },
    "dependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.10",
        "bcryptjs": "^2.4.3",
        "body-parser": "^2.2.2",
        "cors": "^2.8.6",
        "date-fns": "^4.1.0",
        "dotenv": "^17.4.0",
        "express": "^5.2.1",
        "express-jwt": "^8.5.1",
        "jsonata": "^2.1.0",
        "jsonwebtoken": "^9.0.3",
        "morgan": "^1.10.1",
        "tsconfig-paths": "^4.2.0"
    }
}